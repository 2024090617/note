# GitHub personal access token (required for private repos, higher rate limits)
GITHUB_TOKEN=ghp_xxxxxxxxxxxx

# GitHub API URL (change for GitHub Enterprise)
# GITHUB_API_URL=https://api.github.com

# Directory where repositories are cloned
# GITHUB_CLONE_DIR=~/github-repos

# HTTP timeout in seconds
# GITHUB_TIMEOUT=30

# Maximum download size in bytes (default 500 MB)
# GITHUB_MAX_DOWNLOAD_SIZE=524288000
